<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cs_social_procedure_view_list" model="ir.ui.view">
            <field name="name">cs.social.procedure.list</field>
            <field name="model">cs.social.procedure</field>
            <field name="arch" type="xml">
                <list string="Gestiones y trámites" decoration-danger="due_date and due_date &lt; current_date and state not in ('done', 'cancelled')" decoration-muted="state == 'cancelled'" decoration-success="state == 'done'">
                    <field name="name"/>
                    <field name="request_date"/>
                    <field name="resident_id"/>
                    <field name="social_worker_id"/>
                    <field name="procedure_type"/>
                    <field name="organism"/>
                    <field name="due_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="cs_social_procedure_view_form" model="ir.ui.view">
            <field name="name">cs.social.procedure.form</field>
            <field name="model">cs.social.procedure</field>
            <field name="arch" type="xml">
                <form string="Gestión / trámite">
                    <header>
                        <button name="action_start" string="Iniciar trámite" type="object" class="oe_highlight" invisible="state != 'pending'"/>
                        <button name="action_wait" string="Esperando respuesta" type="object" invisible="state != 'in_progress'"/>
                        <button name="action_mark_done" string="Completar" type="object" class="oe_highlight" invisible="state not in ('in_progress', 'waiting')"/>
                        <button name="action_mark_cancelled" string="Cancelar" type="object" invisible="state in ('done', 'cancelled')"/>
                        <button name="action_set_pending" string="Reabrir" type="object" invisible="state not in ('done', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,waiting,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="General">
                                <field name="resident_id"/>
                                <field name="partner_id"/>
                                <field name="social_worker_id"/>
                                <field name="procedure_type"/>
                                <field name="organism"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group string="Fechas">
                                <field name="request_date"/>
                                <field name="due_date"/>
                                <field name="completion_date"/>
                            </group>
                        </group>
                        <group string="Descripción">
                            <field name="description" nolabel="1" colspan="2" placeholder="Qué se solicita, para qué y ante quién..."/>
                        </group>
                        <group string="Notas / seguimiento">
                            <field name="notes" nolabel="1" colspan="2" placeholder="Avances, llamadas realizadas, documentación pendiente..."/>
                        </group>
                        <group string="Archivos adjuntos (PDF, imágenes, etc.)">
                            <field name="attachment_ids" nolabel="1" colspan="2" widget="many2many_binary"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="cs_social_procedure_view_search" model="ir.ui.view">
            <field name="name">cs.social.procedure.search</field>
            <field name="model">cs.social.procedure</field>
            <field name="arch" type="xml">
                <search string="Gestiones">
                    <field name="name"/>
                    <field name="resident_id"/>
                    <field name="social_worker_id"/>
                    <field name="organism"/>
                    <separator/>
                    <filter name="open" string="Abiertas" domain="[('state', 'not in', ('done', 'cancelled'))]"/>
                    <filter name="done" string="Completadas" domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <filter name="overdue" string="Fuera de plazo" domain="[('due_date', '&lt;', 'today'), ('state', 'not in', ('done', 'cancelled'))]"/>
                    <group>
                        <filter name="group_type" string="Tipo de gestión" context="{'group_by': 'procedure_type'}"/>
                        <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                        <filter name="group_resident" string="Residente" context="{'group_by': 'resident_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="cs_social_procedure_action" model="ir.actions.act_window">
            <field name="name">Gestiones y trámites</field>
            <field name="res_model">cs.social.procedure</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_open': 1}</field>
        </record>
    </data>
</odoo>
